{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "leading_diamond": "\u256d\u2500\ue0b6",
          "trailing_diamond": "\ue0b0",
          "template": " \uf120 {{ .Name }} ",
          "foreground": "#f8f8f2",
          "background": "#6272a4",
          "type": "shell",
          "style": "diamond"
        },
        {
          "template": " {{ .UserName }} ",
          "foreground": "#44475a",
          "powerline_symbol": "\ue0b0",
          "background": "#00FFCC",
          "type": "session",
          "style": "powerline"
        },
        {
          "template": " in ",
          "foreground": "#f8f8f2",
          "powerline_symbol": "\ue0b0",
          "background": "#44475a",
          "type": "text",
          "style": "powerline"
        },
        {
          "template": " \uf0e7 root ",
          "foreground": "#f8f8f2",
          "powerline_symbol": "\ue0b0",
          "background": "#ff5555",
          "type": "root",
          "style": "powerline"
        },
        {
          "options": {
            "folder_separator_icon": "/",
            "style": "unique"
          },
          "template": " \uf07c {{ .Path }} ",
          "foreground": "#44475a",
          "powerline_symbol": "\ue0b0",
          "background": "#00FFCC",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{ if or (.Working.Changed) (.Working.Untracked) }} \uf044 {{ .Working.String }}{{ end }}{{ if and (or (.Working.Changed) (.Working.Untracked)) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#282a36",
          "powerline_symbol": "\ue0b0",
          "background": "#28c4cf",
          "type": "git",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u2570\u2500",
          "foreground": "#6272a4",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": "\uf054",
          "foreground": "#00FFCC",
          "type": "status",
          "style": "diamond",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff5555{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 4,
  "final_space": true
}
